DJANGO_DEBUG=True
DJANGO_SECRET_KEY=change-me
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# local keeps uploads under MEDIA_ROOT. Use s3 in AWS.
CLOUDVAULT_STORAGE_BACKEND=local
CLOUDVAULT_MAX_UPLOAD_SIZE=10485760

# Required when CLOUDVAULT_STORAGE_BACKEND=s3.
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=eu-east-1

# Optional production database. If omitted, SQLite is used.
DATABASE_URL=
